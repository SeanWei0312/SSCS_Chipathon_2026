C {code_shown.sym} 120 -310 0 0 {name=SPICE only_toplevel=false value="
.include "/foss/designs/test_counter/pex/counter.spice"
XDUT clk count0 count1 count2 count3 VDD VSS counter

.control
set noaskquit
set filetype=binary
save v(clk) v(count0) v(count1) v(count2) v(count3) i(vamm2)
tran 1n 40u
write current_mirror_cosim.raw v(clk) v(count0) v(count1) v(count2) v(count3) i(vamm2)
.endc
"}
